1.BANK ACCOUNT TRANSACTION:[type:1)deposit 2)withdrawal]
   withdraw only if amount >= 1000 and intial,deposi atleast 500 
display updated balance

a=int(input("enter the initial amount"))
if a<1000:
    print("initial amt should greater than 1000")
else:
    c=int(input("enter transaction mode:"))
    if c==1:
        da=int(input("deposit amt:"))
        if da<500:
            print("deposit amt should greater than 500")
        else:
            ta=a+da
            print("amount deposited successfully,,,,balance:",ta)
    elif c==2:
        wa=int(input("enter withdrawal amt:"))
        if wa<500:
            print("withdrawal amt should greater than 500")
            if wa<1:
                print("invalid amount entered")
            else:
                ta=a-wa
                if ta<1000:
                    print("withdrawal amt should greater than 1000")
                else:
                    print("balance:",ta)
    else:
        print("invalid choice"
